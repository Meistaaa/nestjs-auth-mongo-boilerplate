# Application
ENVIRONMENT=development
PORT=3000
CORS_ORIGIN=http://localhost:3000

# Session
SESSION_SECRET=replace-with-at-least-32-random-chars

# MongoDB
MONGO_URI=mongodb://localhost:27017
DB_NAME=africonn

# Redis
# Prefer REDIS_URL when available.
REDIS_URL=redis://127.0.0.1:6379/0

# Use these if REDIS_URL is not set.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_USERNAME=
REDIS_PASSWORD=

# Email (Nodemailer)
# If MAIL_HOST is omitted, the app falls back to MAIL_SERVICE.
MAIL_SERVICE=gmail
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_FROM=
MAIL_USER=
MAIL_PASS=
